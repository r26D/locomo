# Copy to `.env.docker` for repo-local secrets (gitignored via `.env.*`).
# Prefer a file outside the repo for production keys, e.g.:
#   export LOCOMO_COMPOSE_ENV_FILE="$HOME/.config/locomo/secrets.env"
#   task docker:run ENV_FILE="$HOME/.config/locomo/secrets.env" -- bash scripts/evaluate_gpts.sh
#
# Install Task: https://taskfile.dev/installation/

# LOCOMO_OPENAI_API_KEY=
# LOCOMO_ANTHROPIC_API_KEY=
# LOCOMO_GOOGLE_API_KEY=
# LOCOMO_HF_TOKEN=

# Optional (see scripts/env.sh):
# LOCOMO_OPENAI_CHAT_MODEL=gpt-4o-mini
# LOCOMO_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# LOCOMO_CLAUDE_SONNET_MODEL=claude-3-5-sonnet-20241022
# LOCOMO_CLAUDE_HAIKU_MODEL=claude-3-5-haiku-20241022

# Optional path overrides inside the container (defaults match scripts/env.sh):
# OUT_DIR=./outputs
# EMB_DIR=./outputs
# DATA_FILE_PATH=./data/locomo10.json
# PROMPT_DIR=./prompt_examples

# Compose only: `user:` in docker-compose.yml uses host env substitution.
# Export before `docker compose` so mounted dirs match your UID/GID (not read from this file):
#   export DOCKER_UID=$(id -u) DOCKER_GID=$(id -g)
